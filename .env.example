# QuantForge — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.

# =============================================================================
# === Required: LLM API (pick one or both)
# =============================================================================

# OpenRouter (recommended — routes to any model)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Anthropic direct (used by quantforge_reflect.py and research agent)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Groq (optional, used by some fast-inference paths)
GROQ_API_KEY=your-groq-api-key-here

# =============================================================================
# === Required: Base directory
# =============================================================================

# Root directory where QuantForge stores data, logs, and artifacts.
# Defaults to ~/quantforge if not set.
QF_BASE_DIR=~/quantforge

# =============================================================================
# === Production host detection
# =============================================================================

# Hostname of your production/server machine (the one that runs cron jobs).
# If unset, runtime-guard checks will block production-only scripts.
QF_PRODUCTION_HOST=your-prod-hostname

# Set to 1 to allow production scripts to run locally (for development only).
QF_ALLOW_LOCAL_RUNTIME=

# =============================================================================
# === Remote status fetching (quantforge_zero_budget_status.py)
# =============================================================================

# SSH connection details for the production host
QF_PROD_SSH_HOST=your-server-hostname-or-ip
QF_PROD_SSH_USER=youruser
QF_PROD_SSH_PORT=22

# Optional: HTTP URL to a running QuantForge dashboard status endpoint
QUANTFORGE_DASHBOARD_STATUS_URL=

# Source dir override for reading artifacts locally (CI / testing)
QUANTFORGE_SOURCE_DIR=
QUANTFORGE_STATUS_OUTPUT_DIR=runtime/offhost/status

# =============================================================================
# === Supabase (optional — used by quantforge_history_summary.py)
# =============================================================================

# Your Supabase project URL (e.g. https://xxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Service-role key (has full DB access — keep this secret)
SUPABASE_SERVICE_KEY=

# Anonymous/public key (read-only, safe for client-side use)
SUPABASE_ANON_KEY=

# The agent_key value stored in your Supabase operator cycles table.
# Defaults to "quantforge" if not set.
QF_SUPABASE_AGENT_KEY=quantforge

# Name of the Supabase table holding operator cycle history.
# Defaults to "quantforge_operator_cycles" if not set.
QF_SUPABASE_TABLE=quantforge_operator_cycles

# =============================================================================
# === ML / Research tuning (all optional)
# =============================================================================

# Forward-return horizon for ML models ("1h", "4h", "24h")
QF_HORIZON=4h

# Maximum rows per coin when training (lower = faster, higher = more data)
QF_MAX_ROWS=3000

# Minimum labeled rows required to train a model
QF_MIN_LABELED_ROWS=200

# Minimum 1h candles required before modeling a coin
QF_MIN_1H_CANDLES=500

# Drop NaN rows from features ("true"/"false")
QF_KEEP_NAN=false

# NaN prefunding strategy
QF_NAN_PREFUNDING=

# Objective mode for ML trainer ("auc", "pnl")
QF_OBJECTIVE_MODE=auc

# Symbol allowlist (comma-separated, e.g. "BTC-USDT,ETH-USDT")
QF_SYMBOL_ALLOWLIST=

# Research slice profile
QF_SLICE_PROFILE=

# Carry research tuning
QF_HALFLIFE_DAYS=
QF_HURDLE_MULT=
QF_MACRO=

# Cross-venue carry probe settings
XVENUE_COST_BPS=
XVENUE_START_MS=

# =============================================================================
# === Optional integrations
# =============================================================================

# Path to an Obsidian vault for self-heal action notes (optional).
# Leave unset to disable; falls back to a sensible default if used.
OBSIDIAN_VAULT_PATH=

# Trigger file an external alert/monitor agent polls for event-driven analysis.
# Defaults to ~/.quantforge/alert_trigger.json if not set.
QF_ALERT_TRIGGER_FILE=
